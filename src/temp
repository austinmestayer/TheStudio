       PROCEDURE DIVISION.
       MAINLINE-ROUTINE.
           PERFORM Z000-OPEN-FILES.
           PERFORM P000-PRINT-HEADING.
           PERFORM B000-BEGIN-INGEST.
           PERFORM P400-PRINT-COUNTS.
           PERFORM Z100-CLOSE-FILES.

           MOVE 0 TO RETURN-CODE.
           STOP RUN.


      ****************************************************************
      * ROUTINE TO BEGIN RECORD INGEST                               *
      ****************************************************************
       B000-BEGIN-INGEST.
           PERFORM R000-READ-NEXT-RECORD.
           MOVE POLICY-CODE TO W-POLICY-CODE-TEMP.
           MOVE RECORD-CODE TO W-RECORD-CODE-TEMP.
           MOVE POLICY-HEADER TO W-POLICY-HEADER-TEMP.
               PERFORM B100-PROCESS-POLICY-GROUP
                   UNTIL ALL-POLICIES-PROCESSED-SW = 'YES'.
           SUBTRACT 1 FROM A-RECORDS-INPUT.
      ****************************************************************
      * ROUTINE TO PROCESS POLICY GROUP AND POPULATE CONSTRUCTS      *
      ****************************************************************
       B100-PROCESS-POLICY-GROUP.

           PERFORM C000-CHECK-SEQUENCING.


           IF POLICY-CODE = W-POLICY-CODE-TEMP
              AND W-POLICY-HEADER-TEMP = 'A '
              IF RECORD-CODE = '10'
                 MOVE 'YES' TO POLICY-HAS-10-SW
                 MOVE DISK-IN-RECORD TO W-TYPE-10
                 PERFORM R100-NEXT-RECORD
              ELSE IF RECORD-CODE = '20'
                 MOVE DISK-IN-RECORD TO W-TYPE-20
                 MOVE 'YES' TO POLICY-HAS-20-SW
                 PERFORM R100-NEXT-RECORD
              ELSE IF RECORD-CODE = '32'
                 MOVE DISK-IN-RECORD TO W-TYPE-32
                 MOVE 'YES' TO POLICY-HAS-32-SW
                 PERFORM R100-NEXT-RECORD
              ELSE IF RECORD-CODE = '60'
                 MOVE DISK-IN-RECORD TO W-TYPE-60
                 MOVE 'YES' TO POLICY-HAS-60-SW
                 PERFORM R100-NEXT-RECORD
              ELSE IF RECORD-CODE = '94'
                 MOVE DISK-IN-RECORD TO W-TYPE-94
                 MOVE 'YES' TO POLICY-HAS-94-SW
                 PERFORM R100-NEXT-RECORD
              END-IF

           ELSE IF W-POLICY-HEADER-TEMP = 'A '
                 PERFORM B200-CHECK-FOR-ERRORS
                 MOVE POLICY-CODE TO W-POLICY-CODE-TEMP
                 MOVE POLICY-HEADER TO W-POLICY-HEADER-TEMP
                 MOVE RECORD-CODE TO W-RECORD-CODE-TEMP
                 MOVE 'NO' TO POLICY-HAS-10-SW
                              POLICY-HAS-20-SW
                              POLICY-HAS-32-SW
                              POLICY-HAS-60-SW
                              POLICY-HAS-94-SW

           ELSE IF POLICY-HEADER NOT EQUAL 'A '
                 MOVE 'NO' TO POLICY-HAS-10-SW
                              POLICY-HAS-20-SW
                              POLICY-HAS-32-SW
                              POLICY-HAS-60-SW
                              POLICY-HAS-94-SW
                 MOVE DISK-IN-RECORD TO W-TYPE-10
                 PERFORM B150-PROCESS-BAD-POLICY
                 PERFORM R100-NEXT-RECORD
                 IF END-OF-FILE-SW = 'YES'
                    MOVE 'YES' TO ALL-POLICIES-PROCESSED-SW
                 END-IF

           ELSE
               PERFORM R100-NEXT-RECORD
           END-IF.

      ****************************************************************
      * ROUTINE TO PROCESS POLICY WITH INCRORRECT POLICY CODE        *
      ****************************************************************
       B150-PROCESS-BAD-POLICY.

           IF RECORD-CODE = '10'
              IF W-10-POLICY-HEADER NOT EQUAL 'A '
                 PERFORM B210-EVALUATE-TYPE-10
                 MOVE 'YES' TO POLICY-HAS-10-SW
              END-IF
           ELSE IF RECORD-CODE = '20'
              IF W-20-POLICY-HEADER NOT EQUAL 'A '
                 PERFORM B220-EVALUATE-TYPE-20
                 MOVE 'YES' TO POLICY-HAS-20-SW
              END-IF
           ELSE IF RECORD-CODE = '32'
              IF W-32-POLICY-HEADER NOT EQUAL 'A '
                 PERFORM B232-EVALUATE-TYPE-32
                 MOVE 'YES' TO POLICY-HAS-32-SW
              END-IF
           ELSE IF RECORD-CODE = '60'
              IF W-60-POLICY-HEADER NOT EQUAL 'A '
                 PERFORM B260-EVALUATE-TYPE-60
                 MOVE 'YES' TO POLICY-HAS-60-SW
              END-IF
           ELSE IF RECORD-CODE = '94'
              IF W-94-POLICY-HEADER NOT EQUAL 'A '
                 PERFORM B294-EVALUATE-TYPE-94
                 MOVE 'YES' TO POLICY-HAS-94-SW
              END-IF
           END-IF.

           IF POLICY-HAS-10-SW = 'NO'
              MOVE '10' TO W-RECORD-NUMBER-3
              PERFORM B205-PRINT-MISSING-RECORD
           END-IF.
           IF POLICY-HAS-20-SW = 'NO'
              MOVE '20' TO W-RECORD-NUMBER-3
              PERFORM B205-PRINT-MISSING-RECORD
           END-IF.
           IF POLICY-HAS-32-SW = 'NO'
              MOVE '32' TO W-RECORD-NUMBER-3
              PERFORM B205-PRINT-MISSING-RECORD
           END-IF.
           IF POLICY-HAS-60-SW = 'NO'
              MOVE '60' TO W-RECORD-NUMBER-3
              PERFORM B205-PRINT-MISSING-RECORD
           END-IF.
           IF POLICY-HAS-94-SW = 'NO'
              MOVE '94' TO W-RECORD-NUMBER-3
              PERFORM B205-PRINT-MISSING-RECORD
           END-IF.


           IF POLICY-ERROR-SW = 'YES'
               PERFORM P300-PRINT-TO-ERROR-OUT
               MOVE 'NO' TO POLICY-ERROR-SW
           ELSE
               PERFORM P200-PRINT-TO-DISK-OUT
           END-IF.

      *****************************************************************
      * ROUTINE TO DIRECT ERROR CHECKING TO APPROPRIATE ROUTINE       *
      *****************************************************************
       B200-CHECK-FOR-ERRORS.
           IF POLICY-HAS-10-SW = 'YES' PERFORM B210-EVALUATE-TYPE-10
           ELSE
              MOVE '10' TO W-RECORD-NUMBER-3
              PERFORM B205-PRINT-MISSING-RECORD
           END-IF.
           IF POLICY-HAS-20-SW = 'YES' PERFORM B220-EVALUATE-TYPE-20
           ELSE
              MOVE '20' TO W-RECORD-NUMBER-3
              PERFORM B205-PRINT-MISSING-RECORD
           END-IF.
           IF POLICY-HAS-32-SW = 'YES' PERFORM B232-EVALUATE-TYPE-32
           ELSE
              MOVE '32' TO W-RECORD-NUMBER-3
              PERFORM B205-PRINT-MISSING-RECORD
           END-IF.
           IF POLICY-HAS-60-SW = 'YES' PERFORM B260-EVALUATE-TYPE-60
           ELSE
              MOVE '60' TO W-RECORD-NUMBER-3
              PERFORM B205-PRINT-MISSING-RECORD
           END-IF.
           IF POLICY-HAS-94-SW = 'YES' PERFORM B294-EVALUATE-TYPE-94
           ELSE
              MOVE '94' TO W-RECORD-NUMBER-3
              PERFORM B205-PRINT-MISSING-RECORD
           END-IF.

           IF POLICY-ERROR-SW = 'YES'
               PERFORM P300-PRINT-TO-ERROR-OUT
               MOVE 'NO' TO POLICY-ERROR-SW
           ELSE
               PERFORM P200-PRINT-TO-DISK-OUT
           END-IF.
      *****************************************************************
      * ROUTINE TO PRINT MISSING RECORD FROM POLICY GROUP             *
      *****************************************************************
       B205-PRINT-MISSING-RECORD.
           MOVE 'YES' TO POLICY-ERROR-SW.
           MOVE POLICY-HEADER TO W-POLICY-HEADER-1.
           MOVE W-POLICY-CODE-TEMP TO W-POLICY-NUMBER-2.

           IF (LINE-COUNT + 2) GREATER THAN MAX-LINES
              PERFORM P000-PRINT-HEADING
           END-IF.

           WRITE PRINTLINE-PRINT FROM W-MISSING-POLICY-ERROR.
           WRITE PRINTLINE-PRINT FROM BLANK-LINE.
           ADD 2 TO LINE-COUNT.
      *****************************************************************
      * ROUTINE TO EVALUATE TYPE 10 RECORDS FOR ERRORS                *
      *****************************************************************
       B210-EVALUATE-TYPE-10.
           MOVE ALL SPACES TO W-TYPE-10-ERROR-IDENTIFIER.
           MOVE ALL SPACES TO W-ERROR-DESCRIPTION.
           IF W-10-POLICY-HEADER NOT EQUAL 'A '
                MOVE ALL '*' TO W-ERROR-10-POLICY-HEADER
                MOVE 'ERROR: POLICY NUMBER DOES NOT START WITH "A "'
                    TO W-ERROR-1-DESCRIPTION
                MOVE 'YES' TO ERROR-FOUND-SW.

           IF W-10-POLICY-NUMBER NOT NUMERIC
                MOVE ALL '*' TO W-ERROR-10-POLICY-NUMBER
                MOVE 'ERROR: INVALID POLICY NUMBER'
                    TO W-ERROR-2-DESCRIPTION
                MOVE 'YES' TO ERROR-FOUND-SW.

           PERFORM B215-EDIT-TYPE-10-DATE.

           IF ERROR-FOUND-SW = 'YES'
              PERFORM P110-PRINT-ERROR-10
              MOVE 'YES' TO POLICY-ERROR-SW.
           MOVE 'NO' TO ERROR-FOUND-SW.
      *****************************************************************
      * ROUTINE TO EDIT EFFECTIVE AND EXPIRATION DATES FOR TYPE 10    *
      *****************************************************************
       B215-EDIT-TYPE-10-DATE.

           MOVE SPACES TO DATE-RECORD.
           MOVE W-10-EFFECTIVE-DATE TO D-FROM-DATE.
           MOVE '1' TO D-ACTIVITY.
           CALL 'A59933P' USING DATE-RECORD.
           IF D-RETURN-CODE NOT EQUAL SPACES
               MOVE ALL '*' TO W-ERROR-10-EFFECTIVE-DATE
               MOVE 'ERROR: INVALID EFFECTIVE DATE'
                    TO W-ERROR-3-DESCRIPTION
               MOVE 'YES' TO ERROR-FOUND-SW
           END-IF.


           MOVE SPACES TO DATE-RECORD.
           MOVE W-10-EXPIRATION-DATE TO D-FROM-DATE.
           MOVE '1' TO D-ACTIVITY.
           CALL 'A59933P' USING DATE-RECORD.
           IF D-RETURN-CODE NOT EQUAL SPACES
               MOVE ALL '*' TO W-ERROR-10-EXPIRATION-DATE
               MOVE 'ERROR: EXPIRATION DATE OUT OF RANGE'
                    TO W-ERROR-4-DESCRIPTION
               MOVE 'YES' TO ERROR-FOUND-SW
           END-IF.


           MOVE CURRENT-DATE TO STORAGE-DATE.
           MOVE '10' TO W-AMOUNT-OF-YEARS.
           PERFORM X000-GET-PAST-DATE UNTIL W-AMOUNT-OF-YEARS = 0.
           MOVE SPACES TO DATE-RECORD.
           MOVE CURRENT-DATE TO D-FROM-DATE.
           MOVE 365 TO D-NUMBER-OF-DAYS.
           MOVE '2' TO D-ACTIVITY.
           CALL 'A59933P' USING DATE-RECORD.
           IF W-10-EFFECTIVE-DATE GREATER THAN D-RETURN-DATE
               MOVE ALL '*' TO W-ERROR-10-EFFECTIVE-DATE
               MOVE 'ERROR: EFFECTIVE DATE OUT OF RANGE'
                    TO W-ERROR-5-DESCRIPTION
               MOVE 'YES' TO ERROR-FOUND-SW
           END-IF.

           IF W-10-EFFECTIVE-DATE LESS THAN STORAGE-DATE
               MOVE ALL '*' TO W-ERROR-10-EFFECTIVE-DATE
               MOVE 'ERROR: EFFECTIVE DATE OUT OF RANGE'
                    TO W-ERROR-5-DESCRIPTION
               MOVE 'YES' TO ERROR-FOUND-SW
           END-IF.
      *****************************************************************
      * ROUTINE TO EVALUATE TYPE 20 RECORDS FOR ERRORS                *
      *****************************************************************
       B220-EVALUATE-TYPE-20.
           MOVE ALL SPACES TO W-TYPE-20-ERROR-IDENTIFIER.
           MOVE ALL SPACES TO W-ERROR-DESCRIPTION.
           IF W-20-POLICY-HEADER NOT EQUAL 'A '
                MOVE ALL '*' TO W-ERROR-20-POLICY-HEADER
                MOVE 'ERROR: POLICY NUMBER DOES NOT START WITH "A "'
                    TO W-ERROR-1-DESCRIPTION
                MOVE 'YES' TO ERROR-FOUND-SW.

           IF W-20-MEMBER-NUMBER NOT NUMERIC
                MOVE ALL '*' TO W-ERROR-20-MEMBER-NUMBER
                MOVE 'ERROR: INVALID MEMBER NUMBER'
                    TO W-ERROR-2-DESCRIPTION
                MOVE 'YES' TO ERROR-FOUND-SW.

           IF ERROR-FOUND-SW = 'YES'
              PERFORM P120-PRINT-ERROR-20
              MOVE 'YES' TO POLICY-ERROR-SW.
           MOVE 'NO' TO ERROR-FOUND-SW.
      *****************************************************************
      * ROUTINE TO EVALUATE TYPE 32 RECORDS FOR ERRORS                *
      *****************************************************************
       B232-EVALUATE-TYPE-32.
           MOVE ALL SPACES TO W-TYPE-32-ERROR-IDENTIFIER.
           MOVE ALL SPACES TO W-ERROR-DESCRIPTION.

           IF W-32-POLICY-HEADER NOT EQUAL 'A '
                MOVE ALL '*' TO W-ERROR-32-POLICY-HEADER
                MOVE 'ERROR: POLICY NUMBER DOES NOT START WITH "A "'
                    TO W-ERROR-1-DESCRIPTION
                MOVE 'YES' TO ERROR-FOUND-SW.

           IF W-32-POLICY-NUMBER NOT NUMERIC
                MOVE ALL '*' TO W-ERROR-32-POLICY-NUMBER
                MOVE 'ERROR: INVALID POLICY NUMBER'
                    TO W-ERROR-2-DESCRIPTION
                MOVE 'YES' TO ERROR-FOUND-SW.
           IF W-32-ZIP-CODE NOT NUMERIC
                MOVE ALL '*' TO W-ERROR-32-ZIP-CODE
                MOVE 'ERROR: INVALID ZIP CODE'
                    TO W-ERROR-3-DESCRIPTION
                MOVE 'YES' TO ERROR-FOUND-SW.

           IF ERROR-FOUND-SW = 'YES'
              PERFORM P132-PRINT-ERROR-32
              MOVE 'YES' TO POLICY-ERROR-SW.
           MOVE 'NO' TO ERROR-FOUND-SW.
      *****************************************************************
      * ROUTINE TO EVALUATE TYPE 60 RECORDS FOR ERRORS                *
      *****************************************************************
       B260-EVALUATE-TYPE-60.
           MOVE ALL SPACES TO W-TYPE-60-ERROR-IDENTIFIER.
           MOVE ALL SPACES TO W-ERROR-DESCRIPTION.
           IF W-60-POLICY-HEADER NOT EQUAL 'A '
                MOVE ALL '*' TO W-ERROR-60-POLICY-HEADER
                MOVE 'ERROR: POLICY NUMBER DOES NOT START WITH "A "'
                    TO W-ERROR-1-DESCRIPTION
                MOVE 'YES' TO ERROR-FOUND-SW.

           IF W-60-MODEL-YEAR NOT NUMERIC
                IF W-60-MODEL-YEAR NOT EQUAL SPACES
                    MOVE ALL '*' TO W-ERROR-60-MODEL-YEAR
                    MOVE 'ERROR: INVALID MODEL YEAR'
                       TO W-ERROR-2-DESCRIPTION
                    MOVE 'YES' TO ERROR-FOUND-SW
                END-IF
           END-IF.
           IF W-60-MODEL-YEAR NUMERIC
                ADD 1 TO CURRENT-YEAR
                IF W-60-MODEL-YEAR GREATER THAN CURRENT-YEAR
                    MOVE ALL '*' TO W-ERROR-60-MODEL-YEAR
                    MOVE 'ERROR: INVALID MODEL YEAR'
                       TO W-ERROR-3-DESCRIPTION
                    MOVE 'YES' TO ERROR-FOUND-SW
                END-IF
                SUBTRACT 1 FROM CURRENT-YEAR
           END-IF.
           IF W-60-NUMBER-OF-CYLINDERS NOT NUMERIC
                IF W-60-NUMBER-OF-CYLINDERS NOT EQUAL SPACES
                    MOVE ALL '*' TO W-ERROR-60-NUMBER-OF-CYLINDERS
                    MOVE 'ERROR: INVALID NUMBER OF CYLINDERS'
                       TO W-ERROR-4-DESCRIPTION
                    MOVE 'YES' TO ERROR-FOUND-SW
                END-IF
           END-IF.
           IF W-60-NUMBER-OF-CYLINDERS NUMERIC
                IF W-60-NUMBER-OF-CYLINDERS NOT EQUAL 4
                     IF W-60-NUMBER-OF-CYLINDERS NOT EQUAL 6
                          IF W-60-NUMBER-OF-CYLINDERS NOT EQUAL 8
                            MOVE ALL '*'
                                TO W-ERROR-60-NUMBER-OF-CYLINDERS
                            MOVE 'ERROR: INVALID NUMBER OF CYLINDERS'
                                TO W-ERROR-4-DESCRIPTION
                            MOVE 'YES' TO ERROR-FOUND-SW
                          END-IF
                     END-IF
                END-IF
           END-IF.
           IF W-60-AGE NOT NUMERIC
                IF W-60-AGE NOT EQUAL SPACES
                    MOVE ALL '*' TO W-ERROR-60-AGE
                    MOVE 'ERROR: INVALID AGE'
                       TO W-ERROR-5-DESCRIPTION
                    MOVE 'YES' TO ERROR-FOUND-SW
                END-IF
           ELSE IF W-60-AGE NUMERIC
                IF W-60-AGE LESS THAN 1 OR GREATER THAN 6
                    MOVE ALL '*' TO W-ERROR-60-AGE
                    MOVE 'ERROR: INVALID AGE'
                       TO W-ERROR-5-DESCRIPTION
                    MOVE 'YES' TO ERROR-FOUND-SW
                END-IF
           END-IF.
           IF ERROR-FOUND-SW = 'YES'
              PERFORM P160-PRINT-ERROR-60
              MOVE 'YES' TO POLICY-ERROR-SW.
           MOVE 'NO' TO ERROR-FOUND-SW.

      *****************************************************************
      * ROUTINE TO EVALUATE TYPE 94 RECORDS FOR ERRORS                *
      *****************************************************************
       B294-EVALUATE-TYPE-94.
           MOVE ALL SPACES TO W-TYPE-94-ERROR-IDENTIFIER.
           MOVE ALL SPACES TO W-ERROR-DESCRIPTION.
           IF W-94-POLICY-HEADER NOT EQUAL 'A '
                MOVE ALL '*' TO W-ERROR-94-POLICY-HEADER
                MOVE 'ERROR: POLICY NUMBER DOES NOT START WITH "A "'
                    TO W-ERROR-1-DESCRIPTION
                MOVE 'YES' TO ERROR-FOUND-SW.

           IF W-94-POLICY-NUMBER NOT NUMERIC
                MOVE ALL '*' TO W-ERROR-94-POLICY-NUMBER
