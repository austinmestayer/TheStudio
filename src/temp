      *****************************************************************
      * ROUTINE TO CHECK SORT SEQUENCING INTEGRITY                    *
      *****************************************************************
       C000-CHECK-SEQUENCING.
           IF W-RECORD-CODE-TEMP GREATER THAN RECORD-CODE
               IF W-POLICY-CODE-TEMP GREATER THAN POLICY-CODE
                   IF POLICY-HEADER EQUAL 'A '
                       DISPLAY 'SEQUENCE ERROR: INCORRECT RECORD SORT'
                       DISPLAY W-RECORD-CODE-TEMP
                       DISPLAY DISK-IN-RECORD
                       CALL 'CEE3ABD' USING BY VALUE 12 BY VALUE 1
                   END-IF
               END-IF
           ELSE IF W-POLICY-CODE-TEMP GREATER THAN POLICY-CODE
              IF W-RECORD-CODE-TEMP GREATER THAN OR EQUAL TO RECORD-CODE
                   IF POLICY-HEADER EQUAL 'A '
                      DISPLAY 'SEQUENCE ERROR: INCORRECT POLICY SORT'
                      DISPLAY W-POLICY-CODE-TEMP
                      DISPLAY DISK-IN-RECORD
                      CALL 'CEE3ABD' USING BY VALUE 12 BY VALUE 1
                   END-IF
               END-IF
           END-IF.

      *****************************************************************
      * ROUTINE TO PRINT PAGE HEADINGS.                               *
      *****************************************************************
       P000-PRINT-HEADING.
           MOVE 0 TO LINE-COUNT.
           ADD 1 TO PAGE-COUNT.
           MOVE PAGE-COUNT TO PAGENO.
           WRITE PRINTLINE-PRINT FROM HDR-LINE-ONE
               AFTER ADVANCING PAGE.
           WRITE PRINTLINE-PRINT FROM HDR-LINE-TWO.
           WRITE PRINTLINE-PRINT FROM DATE-HEADER.
           WRITE PRINTLINE-PRINT FROM BLANK-LINE.
           WRITE PRINTLINE-PRINT FROM DASH-HEADER.
           ADD 5 TO LINE-COUNT.

      *****************************************************************
      * ROUTINE TO PRINT ERROR DESCRIPTIONS            *
      *****************************************************************
       P101-PRINT-ERROR-DESCRIPTIONS.

           IF (LINE-COUNT + 5) GREATER THAN MAX-LINES
              PERFORM P000-PRINT-HEADING.

           IF W-ERROR-1-DESCRIPTION NOT EQUAL SPACES
              WRITE PRINTLINE-PRINT FROM W-ERROR-1-DESCRIPTION
              ADD 1 TO LINE-COUNT.
           IF W-ERROR-2-DESCRIPTION NOT EQUAL SPACES
              WRITE PRINTLINE-PRINT FROM W-ERROR-2-DESCRIPTION
              ADD 1 TO LINE-COUNT.
           IF W-ERROR-3-DESCRIPTION NOT EQUAL SPACES
              WRITE PRINTLINE-PRINT FROM W-ERROR-3-DESCRIPTION
              ADD 1 TO LINE-COUNT.
           IF W-ERROR-4-DESCRIPTION NOT EQUAL SPACES
              WRITE PRINTLINE-PRINT FROM W-ERROR-4-DESCRIPTION
              ADD 1 TO LINE-COUNT.
           IF W-ERROR-5-DESCRIPTION NOT EQUAL SPACES
              WRITE PRINTLINE-PRINT FROM W-ERROR-5-DESCRIPTION
              ADD 1 TO LINE-COUNT.

      *****************************************************************
      * ROUTINE TO PRINT ERRED RECORDS TO PRINTLINE                   *
      *****************************************************************
       P110-PRINT-ERROR-10.
           PERFORM P101-PRINT-ERROR-DESCRIPTIONS.
           IF (LINE-COUNT + 3) GREATER THAN MAX-LINES
              PERFORM P000-PRINT-HEADING.
           WRITE PRINTLINE-PRINT FROM W-TYPE-10.
           WRITE PRINTLINE-PRINT FROM W-TYPE-10-ERROR-IDENTIFIER.
           WRITE PRINTLINE-PRINT FROM BLANK-LINE.
           ADD 3 TO LINE-COUNT.

       P120-PRINT-ERROR-20.
           PERFORM P101-PRINT-ERROR-DESCRIPTIONS.
           IF (LINE-COUNT + 3) GREATER THAN MAX-LINES
              PERFORM P000-PRINT-HEADING.
           WRITE PRINTLINE-PRINT FROM W-TYPE-20.
           WRITE PRINTLINE-PRINT FROM W-TYPE-20-ERROR-IDENTIFIER.
           WRITE PRINTLINE-PRINT FROM BLANK-LINE.
           ADD 3 TO LINE-COUNT.

       P132-PRINT-ERROR-32.
           PERFORM P101-PRINT-ERROR-DESCRIPTIONS.
           IF (LINE-COUNT + 3) GREATER THAN MAX-LINES
              PERFORM P000-PRINT-HEADING.
           WRITE PRINTLINE-PRINT FROM W-TYPE-32.
           WRITE PRINTLINE-PRINT FROM W-TYPE-32-ERROR-IDENTIFIER.
           WRITE PRINTLINE-PRINT FROM BLANK-LINE.
           ADD 3 TO LINE-COUNT.

       P160-PRINT-ERROR-60.
           PERFORM P101-PRINT-ERROR-DESCRIPTIONS.
           IF (LINE-COUNT + 3) GREATER THAN MAX-LINES
              PERFORM P000-PRINT-HEADING.
           WRITE PRINTLINE-PRINT FROM W-TYPE-60.
           WRITE PRINTLINE-PRINT FROM W-TYPE-60-ERROR-IDENTIFIER.
           WRITE PRINTLINE-PRINT FROM BLANK-LINE.
           ADD 3 TO LINE-COUNT.

       P194-PRINT-ERROR-94.
           PERFORM P101-PRINT-ERROR-DESCRIPTIONS.
           IF (LINE-COUNT + 3) GREATER THAN MAX-LINES
              PERFORM P000-PRINT-HEADING.
           WRITE PRINTLINE-PRINT FROM W-TYPE-94.
           WRITE PRINTLINE-PRINT FROM W-TYPE-94-ERROR-IDENTIFIER.
           WRITE PRINTLINE-PRINT FROM BLANK-LINE.
           ADD 3 TO LINE-COUNT.

      *****************************************************************
      * ROUTINE TO PRINT ERROR-LESS POLICY GROUP TO DISK-OUT          *
      *****************************************************************
       P200-PRINT-TO-DISK-OUT.
           IF POLICY-HAS-10-SW = 'YES'
              WRITE DISK-OUT-PRINT FROM W-TYPE-10
              ADD 1 TO A-DISKOUT-RECORDS.
           IF POLICY-HAS-20-SW = 'YES'
              WRITE DISK-OUT-PRINT FROM W-TYPE-20
              ADD 1 TO A-DISKOUT-RECORDS.
           IF POLICY-HAS-32-SW = 'YES'
              WRITE DISK-OUT-PRINT FROM W-TYPE-32
              ADD 1 TO A-DISKOUT-RECORDS.
           IF POLICY-HAS-60-SW = 'YES'
              WRITE DISK-OUT-PRINT FROM W-TYPE-60
              ADD 1 TO A-DISKOUT-RECORDS.
           IF POLICY-HAS-94-SW = 'YES'
              WRITE DISK-OUT-PRINT FROM W-TYPE-94
              ADD 1 TO A-DISKOUT-RECORDS.

      *****************************************************************
      * ROUTINE TO PRINT ERRED POLICY GROUP TO ERROR-OUT              *
      *****************************************************************
       P300-PRINT-TO-ERROR-OUT.
           IF POLICY-HAS-10-SW = 'YES'
              WRITE ERROR-OUT-PRINT FROM W-TYPE-10
              ADD 1 TO A-ERRDISK-RECORDS.
           IF POLICY-HAS-20-SW = 'YES'
              WRITE ERROR-OUT-PRINT FROM W-TYPE-20
              ADD 1 TO A-ERRDISK-RECORDS.
           IF POLICY-HAS-32-SW = 'YES'
              WRITE ERROR-OUT-PRINT FROM W-TYPE-32
              ADD 1 TO A-ERRDISK-RECORDS.
           IF POLICY-HAS-60-SW = 'YES'
              WRITE ERROR-OUT-PRINT FROM W-TYPE-60
              ADD 1 TO A-ERRDISK-RECORDS.
           IF POLICY-HAS-94-SW = 'YES'
              WRITE ERROR-OUT-PRINT FROM W-TYPE-94
              ADD 1 TO A-ERRDISK-RECORDS.
      *****************************************************************
      * ROUTINE TO PRINT OUT TOTAL PROCESSED RECORD COUNTS            *
      *****************************************************************
       P400-PRINT-COUNTS.
            MOVE 'TOTAL RECORDS INPUT: ' TO C-DESCRIPTOR-LINE.
            MOVE A-RECORDS-INPUT TO C-VALUE-LINE.
            WRITE PRINTLINE-PRINT FROM DL1-OUTPUT-TOTALS
                                  AFTER ADVANCING 3 LINES.

            MOVE 'TOTAL RECORDS OUTPUT TO DISKOUT: '
                TO C-DESCRIPTOR-LINE.
            MOVE A-DISKOUT-RECORDS TO C-VALUE-LINE.
            WRITE PRINTLINE-PRINT FROM DL1-OUTPUT-TOTALS.

            MOVE 'TOTAL RECORDS OUTPUT TO ERRDISK: '
                TO C-DESCRIPTOR-LINE.
            MOVE A-ERRDISK-RECORDS TO C-VALUE-LINE.
            WRITE PRINTLINE-PRINT FROM DL1-OUTPUT-TOTALS.

      *****************************************************************
      * ROUTINE TO READ NEXT RECORD IN SEQUENCE                       *
      *****************************************************************
       R000-READ-NEXT-RECORD.
           READ DISK-IN
               AT END MOVE 'YES' TO END-OF-FILE-SW.
           ADD 1 TO A-RECORDS-INPUT.

      *****************************************************************
      * ROUTINE TO INCREMENT RECORD                                   *
      *****************************************************************
       R100-NEXT-RECORD.
           MOVE POLICY-CODE TO W-POLICY-CODE-TEMP.
           MOVE RECORD-CODE TO W-RECORD-CODE-TEMP.
           PERFORM R000-READ-NEXT-RECORD.

      *****************************************************************
      * ROUTINE TO GET X AMOUNT OF YEARS PRIOR TO SPECIFIED DATE      *
      *****************************************************************
       X000-GET-PAST-DATE.
           MOVE SPACES TO DATE-RECORD.
           MOVE -365 TO D-NUMBER-OF-DAYS.
           MOVE STORAGE-DATE TO D-FROM-DATE.
           MOVE '2' TO D-ACTIVITY.
           CALL 'A59933P' USING DATE-RECORD.
           MOVE D-RETURN-DATE TO STORAGE-DATE.
           SUBTRACT 1 FROM W-AMOUNT-OF-YEARS.

      *****************************************************************
      *ROUTINE TO ACCEPT DATE AND OPEN FILES                          *
      *****************************************************************
       Z000-OPEN-FILES.
           OPEN INPUT DISK-IN
                OUTPUT DISK-OUT
                       ERROR-OUT
                       PRINTLINE.
           ACCEPT WS-DATE-CARD.
           MOVE WS-DATE-MONTH TO MONTH-OUT
                                 CURRENT-MONTH.
           MOVE WS-DATE-DAY TO DAY-OUT
                               CURRENT-DAY.
           MOVE WS-DATE-YEAR TO YEAR-OUT
                                CURRENT-YEAR.
           MOVE SPACES TO DATE-RECORD.
           MOVE CURRENT-DATE TO D-FROM-DATE.
           MOVE 365 TO D-NUMBER-OF-DAYS.
           MOVE '2' TO D-ACTIVITY.
           CALL 'A59933P' USING DATE-RECORD.
           MOVE D-RETURN-DATE TO W-YEAR-FROM-CURRENT.
      *****************************************************************
      * ROUTINE TO CLOSE FILES.                                       *
      *****************************************************************
       Z100-CLOSE-FILES.
           CLOSE DISK-IN
                 DISK-OUT
                 ERROR-OUT
                 PRINTLINE.



